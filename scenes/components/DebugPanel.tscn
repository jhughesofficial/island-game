[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/components/debug_panel.gd" id="1"]

[node name="DebugPanel" type="PanelContainer"]
script = ExtResource("1")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
theme_override_constants/separation = 6

[node name="Title" type="Label" parent="VBoxContainer"]
text = "🛠 DEBUG  (` to toggle)"
theme_override_font_sizes/font_size = 12

[node name="Add100" type="Button" parent="VBoxContainer"]
text = "+$100"

[node name="Add10K" type="Button" parent="VBoxContainer"]
text = "+$10K"

[node name="Add1M" type="Button" parent="VBoxContainer"]
text = "+$1M"

[node name="Add1B" type="Button" parent="VBoxContainer"]
text = "+$1B"

[node name="Add1T" type="Button" parent="VBoxContainer"]
text = "+$1T"

[node name="Sep" type="HSeparator" parent="VBoxContainer"]

[node name="MaxHeat" type="Button" parent="VBoxContainer"]
text = "Heat → MAX"

[node name="ResetHeat" type="Button" parent="VBoxContainer"]
text = "Heat → 0"

[node name="AddPI" type="Button" parent="VBoxContainer"]
text = "+500 PI"

[node name="Sep2" type="HSeparator" parent="VBoxContainer"]

[node name="TestRetire" type="Button" parent="VBoxContainer"]
text = "Test: Retire Win"

[node name="TestSuicide" type="Button" parent="VBoxContainer"]
text = "Test: Suicide End"
